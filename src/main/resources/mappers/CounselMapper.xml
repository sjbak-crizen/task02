<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.crizen.task02.mapper.CounselMapper">

    <select id="getCounselList" resultType="com.crizen.task02.vo.CounselVO" parameterType="com.crizen.task02.vo.CounselVO">
        SELECT * FROM COUNSEL_INFO
        <where>
            <if test="searchKeyword != null and searchKeyword != ''">
                <if test="searchType == 'writer'">
                    AND counsel_writer LIKE CONCAT('%', #{searchKeyword}, '%')
                </if>
                <if test="searchType == 'date'">
                    AND DATE_FORMAT(counsel_date, '%Y-%m-%d') = #{searchKeyword}
                </if>
                <if test="searchType == 'title'">
                    AND counsel_title LIKE CONCAT('%', #{searchKeyword}, '%')
                </if>
                <if test="searchType == 'title_content'">
                    AND (counsel_title LIKE CONCAT('%', #{searchKeyword}, '%')
                    OR counsel_content LIKE CONCAT('%', #{searchKeyword}, '%'))
                </if>
            </if>
        </where>
        ORDER BY seq_counsel DESC
    </select>

    <select id="getCounsel" parameterType="int" resultType="com.crizen.task02.vo.CounselVO">
        <!-- #{seq_counsel}: Java에서 넘겨준 파라미터 값(글 번호)이 들어갈 자리입니다.
            내부적으로 PreparedStatement를 사용하여 값에 포함된 특수기호를 안전하게 처리하므로 SQL 인젝션 해킹을 막아줍니다.
            [변경 시] ${seq_counsel} (달러 기호)로 바꾸면, 값을 문자열 그대로 쿼리에 이어 붙이기 때문에 해킹 공격에 뚫릴 위험이 매우 높아집니다.
        -->
        SELECT * FROM COUNSEL_INFO WHERE seq_counsel = #{seq_counsel}
    </select>

    <insert id="insertCounsel" parameterType="com.crizen.task02.vo.CounselVO">
        <!-- #{...}: CounselVO 객체에 담긴 데이터(제목, 작성자, 내용)를 안전하게 꺼내어 쿼리에 세팅합니다.
            [참고] 글 번호(seq_counsel)는 테이블 생성 시 AUTO_INCREMENT 속성을 주었기 때문에 INSERT 문에서 생략하면 DB가 알아서 1씩 증가시켜 넣어줍니다.
        -->
        INSERT INTO COUNSEL_INFO (counsel_title, counsel_writer, counsel_content, counsel_date)
        VALUES (#{counsel_title}, #{counsel_writer}, #{counsel_content}, NOW())
    </insert>



    <update id="updateCounsel" parameterType="com.crizen.task02.vo.CounselVO">
        <!-- 요구사항에 맞춰 게시글의 제목과 내용뿐만 아니라 '수정자(modify_id)'와 '수정일시(modify_date)'도 함께 업데이트합니다.
            수정일시는 NOW()를 사용해 쿼리가 실행되는 바로 그 시점의 시간으로 갱신됩니다.
        -->
        UPDATE COUNSEL_INFO
        SET counsel_title = #{counsel_title},
            counsel_content = #{counsel_content},
            modify_id = #{modify_id},
            modify_date = NOW()
        WHERE seq_counsel = #{seq_counsel}
    </update>

    <delete id="deleteCounsel" parameterType="int">
        <!-- 파라미터로 넘어온 글 번호(seq_counsel)에 해당하는 행(Row)을 DB에서 완전히 지워버립니다.
        -->
        DELETE FROM COUNSEL_INFO WHERE seq_counsel = #{seq_counsel}
    </delete>

    <select id="getCommentList" parameterType="int" resultType="com.crizen.task02.vo.CounselCommentVO">
        <!-- 특정 게시글(seq_counsel)에 달린 댓글들만 쏙 빼옵니다.
            ORDER BY comment_date ASC: 댓글은 보통 먼저 쓴 사람(옛날 시간)이 맨 위에 보여야 하므로 오름차순(ASC)으로 정렬합니다.
        -->
        SELECT * FROM COUNSEL_COMMENT WHERE seq_counsel = #{seq_counsel} ORDER BY comment_date ASC
    </select>

    <insert id="insertComment" parameterType="com.crizen.task02.vo.CounselCommentVO">
        <!-- 메인 INSERT 쿼리가 실행되기 전(order="BEFORE")에 특정 값을 DB에서 미리 따와서 객체에 담아주는 매우 유용한 태그입니다.
            SELECT NEXTVAL(seq_counsel_comment): MariaDB의 시퀀스를 호출해 다음 댓글 번호를 미리 발급받습니다.
            keyProperty="seq_comment": 발급받은 번호를 파라미터로 넘어온 'CounselCommentVO'의 'seq_comment' 변수에 쏙 넣어줍니다.
            [장점] 이렇게 하면 INSERT 실행 직후 Java 코드(Controller)에서 vo.getSeq_comment()를 꺼냈을 때, 방금 등록된 댓글의 번호를 즉시 알 수 있어 후속 처리(리다이렉트 등)에 매우 유리합니다.
        -->
        <selectKey keyProperty="seq_comment" resultType="int" order="BEFORE">
            SELECT NEXTVAL(seq_counsel_comment)
        </selectKey>
        INSERT INTO COUNSEL_COMMENT (seq_comment, seq_counsel, comment_content, comment_writer)
        VALUES (#{seq_comment}, #{seq_counsel}, #{comment_content}, #{comment_writer})
    </insert>

    <update id="maskSwearWords">
        <!-- REPLACE(원본문자열, '찾을단어', '바꿀단어') 함수를 사용합니다.
          단어가 여러 개이므로, 안쪽 REPLACE의 결과를 바깥쪽 REPLACE가 다시 받아서 연속적으로 처리하는 '중첩 호출' 방식을 썼습니다.
          이렇게 하면 Java에서 코드를 돌리지 않고 DB 서버 안에서 한 방에 처리되므로 속도가 아주 빠릅니다.
        -->
        UPDATE COUNSEL_INFO
        SET counsel_content = REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(
                                                                      counsel_content, '건성', '*****'), '찌질', '*****'), '말투', '*****'), '뻔뻔', '*****'), '싸가지', '*****')
        <!-- WHERE ... LIKE '%단어%': 게시글 내용 중 해당 욕설이 '포함된' 글만 찾습니다.
          [변경 시] LIKE 대신 '=' 기호를 쓰면, 내용이 딱 "건성" 두 글자인 게시물만 찾기 때문에 실질적으로 작동하지 않습니다.
          [삭제 시] WHERE 절을 지워버리면, 욕설이 없는 멀쩡한 게시글 10만 개도 전부 UPDATE 대상이 되어 불필요하게 DB 성능을 갉아먹습니다.
        -->
        WHERE counsel_content LIKE '%건성%' OR counsel_content LIKE '%찌질%' OR counsel_content LIKE '%말투%'
           OR counsel_content LIKE '%뻔뻔%' OR counsel_content LIKE '%싸가지%'
    </update>

    <delete id="deleteOldCounsels">
        <![CDATA[
        DELETE FROM COUNSEL_INFO WHERE counsel_date <= DATE_SUB(NOW(), INTERVAL 5 DAY)
        ]]>
        <!-- DATE_SUB(기준일, 빼고싶은시간): 날짜를 빼주는 함수입니다. (NOW()는 현재 시간)
          즉, "작성일(counsel_date)이 지금(NOW)으로부터 5일(5 DAY) 전인 날짜보다 작거나 같은(<=) 데이터"를 싹 다 지우라는 뜻입니다.
          [변경 시] 5 DAY를 1 MONTH로 바꾸면 한 달 지난 글이 삭제됩니다.
          <![CDATA[ ... ]]>: 쿼리 안의 부등호(<, <=)를 XML 태그로 오해하지 않도록 순수 문자열로 처리해 주는 역할
        -->
    </delete>

</mapper>